# ============================================================
# ThermaShift Social Media Auto-Poster -- Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit the .env file to version control.
#
# Each platform can be enabled independently. Leave credentials
# blank to skip a platform.
# ============================================================

# --- LinkedIn (Company Page) ---
# Get these from https://developer.linkedin.com/
# Required scopes: w_member_social, w_organization_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# --- X / Twitter ---
# Get these from https://developer.twitter.com/
# Requires Elevated access for posting via API v2
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# --- Reddit ---
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=ThermaShift:v1.0.0 (by /u/YourRedditUsername)

# --- Facebook (Page) ---
# Get these from https://developers.facebook.com/
# Requires a Page Access Token with pages_manage_posts permission
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- Bluesky ---
# Create an App Password at https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_APP_PASSWORD=
BLUESKY_SERVICE=https://bsky.social

# --- Claude API (for chat widget + content generation) ---
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=

# --- Vite (dev mode only — browser-side, remove for production) ---
VITE_ANTHROPIC_API_KEY=

# --- Email Notifications (Resend — free tier: 3,000/month) ---
# Sign up at https://resend.com (no credit card needed)
RESEND_API_KEY=

# --- Stripe (Payments) ---
# Sign up at https://stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- General ---
PORT=3001
LOG_LEVEL=info
